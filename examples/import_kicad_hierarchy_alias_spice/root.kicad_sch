(kicad_sch
  (version 20240101)
  (generator circuitci_fixture)
  (uuid "99999999-9999-9999-9999-999999999999")
  (lib_symbols
    (symbol "Simulation_SPICE:VSOURCE"
      (pin passive line (at 0 0 0) (length 2.54) (number "1"))
      (pin passive line (at 0 10 180) (length 2.54) (number "2"))))

  (symbol (lib_id "Simulation_SPICE:VSOURCE") (at 0 0 0)
    (property "Reference" "V1")
    (property "Value" "3.3V")
    (pin "1") (pin "2"))

  (wire (pts (xy 0 0) (xy 20 0)))
  (wire (pts (xy 0 10) (xy 20 10) (xy 70 10)))
  (wire (pts (xy 50 0) (xy 70 0)))
  (label "SENSE_NODE" (at 60 0 0))

  (sheet (at 20 -10 0) (size 30 30)
    (property "Sheetname" "Filter")
    (property "Sheetfile" "filter.kicad_sch")
    (pin "VIN" input (at 20 0 0))
    (pin "FILTER_OUT" output (at 50 0 0))
    (pin "GND" input (at 20 10 0)))

  (sheet (at 70 -10 0) (size 20 30)
    (property "Sheetname" "Load")
    (property "Sheetfile" "load.kicad_sch")
    (pin "ADC_IN" input (at 70 0 0))
    (pin "GND" input (at 70 10 0)))
)
