(kicad_sch
  (version 20240101)
  (generator circuitci_fixture)
  (uuid "b1000000-0000-4000-8000-000000000001")
  (lib_symbols
    (symbol "Simulation_SPICE:VSOURCE"
      (pin passive line (at 0 0 0) (length 2.54) (number "1"))
      (pin passive line (at 0 30 180) (length 2.54) (number "2"))))

  (symbol (lib_id "Simulation_SPICE:VSOURCE") (at 0 0 0)
    (property "Reference" "V1")
    (property "Value" "3.3V")
    (pin "1") (pin "2"))

  (wire (pts (xy 0 0) (xy 70 0)))
  (label "VIN_SHARED" (at 35 0 0))

  (wire (pts (xy 30 10) (xy 35 10)))
  (label "LEFT_OUT" (at 35 10 0))

  (wire (pts (xy 70 10) (xy 75 10)))
  (label "RIGHT_OUT" (at 75 10 0))

  (wire (pts (xy 0 30) (xy 70 30)))
  (label "GND" (at 35 30 0))

  (sheet (at 20 -10 0) (size 20 50)
    (property "Sheetname" "Left Filter")
    (property "Sheetfile" "filter.kicad_sch")
    (pin "VIN" input (at 20 0 0))
    (pin "OUT" output (at 30 10 0))
    (pin "GND" input (at 20 30 0)))

  (sheet (at 60 -10 0) (size 20 50)
    (property "Sheetname" "Right Filter")
    (property "Sheetfile" "filter.kicad_sch")
    (pin "VIN" input (at 60 0 0))
    (pin "OUT" output (at 70 10 0))
    (pin "GND" input (at 60 30 0)))
)
