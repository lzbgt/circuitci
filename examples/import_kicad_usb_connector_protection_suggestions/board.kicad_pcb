(kicad_pcb
  (version 20240108)
  (generator circuitci_fixture)

  (net 1 "USB_DP")
  (net 2 "USB_DM")
  (net 3 "USB_VBUS")
  (net 4 "GND")

  (net_class "USB_HS" "USB high-speed data"
    (clearance 0.15)
    (trace_width 0.15)
    (diff_pair_width 0.15)
    (diff_pair_gap 0.15)
    (add_net "USB_DP")
    (add_net "USB_DM"))

  (rule "USB data length and skew"
    (condition "A.hasNetclass('USB_HS')")
    (constraint length (max 25mm))
    (constraint skew (max 0.5mm) within_diff_pairs))

  (gr_line (start -0.4 -1.0) (end 2.0 -1.0) (stroke (width 0.05) (type solid)) (layer "Edge.Cuts"))
  (gr_line (start 2.0 -1.0) (end 2.0 1.4) (stroke (width 0.05) (type solid)) (layer "Edge.Cuts"))
  (gr_line (start 2.0 1.4) (end -0.4 1.4) (stroke (width 0.05) (type solid)) (layer "Edge.Cuts"))
  (gr_line (start -0.4 1.4) (end -0.4 -1.0) (stroke (width 0.05) (type solid)) (layer "Edge.Cuts"))
  (gr_circle (center 1.8 1.2) (end 1.9 1.2) (stroke (width 0.05) (type solid)) (fill none) (layer "Edge.Cuts"))
  (gr_arc (start 1.6 1.4) (mid 1.8 1.6) (end 2.0 1.4) (stroke (width 0.05) (type solid)) (layer "Edge.Cuts"))

  (footprint "Connector:USB2" (layer "F.Cu")
    (at 0 0 0)
    (property "Reference" "J1" (at 0 0 0) (layer "F.SilkS"))
    (property "Value" "USB2_CONNECTOR" (at 0 1 0) (layer "F.Fab"))
    (property "CircuitCI_EntryDirectionOffsetDeg" "0.0" (at 0 1.0 0) (layer "F.Fab"))
    (property "CircuitCI_EntryClearanceDepthMM" "2.5" (at 0 1.1 0) (layer "F.Fab"))
    (property "CircuitCI_EntryApertureFrontOffsetMM" "0.0" (at 0 1.2 0) (layer "F.Fab"))
    (property "CircuitCI_EntryApertureLateralOffsetMM" "0.0" (at 0 1.4 0) (layer "F.Fab"))
    (property "CircuitCI_EntryApertureWidthMM" "1.0" (at 0 1.6 0) (layer "F.Fab"))
    (fp_rect (start -0.7 -0.8) (end 0.3 1.2) (stroke (width 0.05) (type solid)) (fill none) (layer "F.Fab"))
    (fp_line (start -0.8 -0.9) (end 0.4 -0.9) (stroke (width 0.05) (type solid)) (layer "F.CrtYd"))
    (fp_poly (pts (xy -0.8 -0.9) (xy 0.4 -0.9) (xy 0.4 1.2) (xy -0.8 1.2)) (stroke (width 0.05) (type solid)) (fill none) (layer "F.Fab"))
    (fp_circle (center 0.2 0.9) (end 0.3 0.9) (stroke (width 0.05) (type solid)) (fill none) (layer "F.Fab"))
    (fp_arc (start 0.0 0.9) (mid 0.1 1.0) (end 0.2 0.9) (stroke (width 0.05) (type solid)) (layer "F.CrtYd"))
    (pad "D+" smd rect (at 0 0.2) (size 0.3 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "USB_DP"))
    (pad "D-" smd rect (at 0 0.4) (size 0.3 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "USB_DM"))
    (pad "VBUS" smd rect (at 0 -0.5) (size 0.3 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "USB_VBUS"))
    (pad "GND" smd rect (at 0 1.02) (size 0.3 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 4 "GND"))
    (pad "SHIELD" smd rect (at -0.5 1.02) (size 0.3 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 4 "GND")))

  (footprint "Protection:TPD2EUSB30" (layer "F.Cu")
    (at 1 0 0)
    (fp_text reference "UESD" (at 0 0 0) (layer "F.SilkS"))
    (property "Value" "TPD2EUSB30" (at 0 1 0) (layer "F.Fab"))
    (fp_rect (start -0.1 -0.1) (end 0.1 0.7) (stroke (width 0.05) (type solid)) (fill none) (layer "F.Fab"))
    (pad "D1+" smd rect (at 0 0.2) (size 0.3 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "USB_DP"))
    (pad "D1-" smd rect (at 0 0.4) (size 0.3 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "USB_DM"))
    (pad "GND" smd rect (at 0 0.8) (size 0.3 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 4 "GND")))

  (footprint "Protection:VBUS_ESD" (layer "F.Cu")
    (at 1.5 0 0)
    (property "Reference" "UVBUS" (at 0 0 0) (layer "F.SilkS"))
    (property "Value" "VBUS_ESD" (at 0 1 0) (layer "F.Fab"))
    (fp_rect (start -0.12 -0.7) (end 0.12 0.9) (stroke (width 0.05) (type solid)) (fill none) (layer "F.Fab"))
    (pad "IO" smd rect (at 0 -0.5) (size 0.3 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "USB_VBUS"))
    (pad "GND" smd rect (at 0 0.8) (size 0.3 0.3) (layers "F.Cu" "F.Paste" "F.Mask") (net 4 "GND")))

  (footprint "MountingHole:NPTH" (layer "F.Cu")
    (at 20 20 0)
    (property "Reference" "H1" (at 0 0 0) (layer "F.SilkS")))

  (segment (start 0 0) (end 1 0) (width 0.15) (layer "F.Cu") (net 1))
  (segment (start 0 0.4) (end 1 0.4) (width 0.15) (layer "F.Cu") (net 2))
  (segment (start 0 -0.5) (end 1.5 -0.5) (width 0.30) (layer "F.Cu") (net 3))
  (via (at 0.5 0.0) (size 0.60) (drill 0.30) (layers "F.Cu" "B.Cu") (net 1))

  (zone (net 4) (net_name "GND") (layer "F.Cu")
    (polygon
      (pts
        (xy -1 -1)
        (xy 2 -1)
        (xy 2 1)
        (xy -1 1)))
    (filled_polygon
      (layer "F.Cu")
      (pts
        (xy -0.9 -0.9)
        (xy 1.9 -0.9)
        (xy 1.9 0.9)
        (xy -0.9 0.9))))
)
