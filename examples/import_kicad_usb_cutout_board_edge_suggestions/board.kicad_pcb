(kicad_pcb
  (version 20240108)
  (generator circuitci_fixture)

  (net 1 "USB_VBUS")
  (net 2 "USB_DP")
  (net 3 "USB_DM")
  (net 4 "GND")

  (gr_line (start 0 0) (end 10 0) (stroke (width 0.05) (type solid)) (layer "Edge.Cuts"))
  (gr_line (start 10 0) (end 10 10) (stroke (width 0.05) (type solid)) (layer "Edge.Cuts"))
  (gr_line (start 10 10) (end 0 10) (stroke (width 0.05) (type solid)) (layer "Edge.Cuts"))
  (gr_line (start 0 10) (end 0 0) (stroke (width 0.05) (type solid)) (layer "Edge.Cuts"))
  (gr_circle (center 5 5) (end 5.2 5) (stroke (width 0.05) (type solid)) (fill none) (layer "Edge.Cuts"))

  (footprint "Connector:USB2" (layer "F.Cu")
    (at 5.2 5 0)
    (property "Reference" "J1" (at 0 0 0) (layer "F.SilkS"))
    (property "Value" "USB2_CONNECTOR" (at 0 1 0) (layer "F.Fab"))
    (fp_poly (pts (xy -0.1 -0.1) (xy 0.1 -0.1) (xy 0.1 0.1) (xy -0.1 0.1)) (stroke (width 0.05) (type solid)) (fill none) (layer "F.Fab"))
    (pad "VBUS" smd rect (at 0 -0.05) (size 0.2 0.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "USB_VBUS"))
    (pad "D+" smd rect (at 0 0.00) (size 0.2 0.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "USB_DP"))
    (pad "D-" smd rect (at 0 0.05) (size 0.2 0.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "USB_DM"))
    (pad "GND" smd rect (at -0.05 0.00) (size 0.2 0.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 4 "GND")))
)
