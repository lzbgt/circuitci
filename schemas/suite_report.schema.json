{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://circuitci.local/schemas/suite_report.schema.json",
  "title": "CircuitCI Validation Suite Report",
  "type": "object",
  "required": [
    "schema_version",
    "suite",
    "validation_profile",
    "result",
    "summary",
    "cases",
    "repairs",
    "reproduction"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "suite": { "type": "string", "minLength": 1 },
    "validation_profile": { "type": "string", "minLength": 1 },
    "result": { "enum": ["pass", "fail"] },
    "summary": {
      "type": "object",
      "required": [
        "cases",
        "passed",
        "failed",
        "repairs",
        "repairs_passed",
        "repairs_failed"
      ],
      "properties": {
        "cases": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "repairs": { "type": "integer", "minimum": 0 },
        "repairs_passed": { "type": "integer", "minimum": 0 },
        "repairs_failed": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "project",
          "expect",
          "actual",
          "result",
          "required_findings",
          "matched_findings",
          "required_artifacts",
          "matched_artifacts",
          "required_waveforms",
          "matched_waveforms",
          "blocking_limitations",
          "report",
          "messages"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "project": { "type": "string", "minLength": 1 },
          "expect": { "enum": ["pass", "fail"] },
          "actual": { "enum": ["pass", "fail"] },
          "result": { "enum": ["pass", "fail"] },
          "required_findings": {
            "type": "array",
            "items": { "$ref": "#/$defs/finding_expectation" }
          },
          "matched_findings": {
            "type": "array",
            "items": { "$ref": "#/$defs/finding_expectation" }
          },
          "required_artifacts": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "matched_artifacts": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "required_waveforms": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "matched_waveforms": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "blocking_limitations": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "report": { "type": "string", "minLength": 1 },
          "messages": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "repairs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "detects_case",
          "fixed_case",
          "fixes_findings",
          "detect_project",
          "fixed_project",
          "detect_report",
          "fixed_report",
          "matched_findings",
          "suggested_fixes",
          "result",
          "messages"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "detects_case": { "type": "string", "minLength": 1 },
          "fixed_case": { "type": "string", "minLength": 1 },
          "fixes_findings": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "detect_project": { "type": "string", "minLength": 1 },
          "fixed_project": { "type": "string", "minLength": 1 },
          "detect_report": { "type": "string", "minLength": 1 },
          "fixed_report": { "type": "string", "minLength": 1 },
          "matched_findings": {
            "type": "array",
            "items": { "$ref": "#/$defs/finding_evidence" }
          },
          "suggested_fixes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "result": { "enum": ["pass", "fail"] },
          "messages": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "reproduction": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "finding_expectation": {
      "type": "object",
      "required": ["id", "severity"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["critical", "warning", "info"] }
      },
      "additionalProperties": false
    },
    "finding_evidence": {
      "type": "object",
      "required": ["id", "severity", "scenario", "message", "suggested_fixes"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["critical", "warning", "info"] },
        "scenario": { "type": "string", "minLength": 1 },
        "component": { "type": "string" },
        "net": { "type": "string" },
        "message": { "type": "string", "minLength": 1 },
        "suggested_fixes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
