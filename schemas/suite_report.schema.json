{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://circuitci.local/schemas/suite_report.schema.json",
  "title": "CircuitCI Validation Suite Report",
  "type": "object",
  "required": [
    "schema_version",
    "suite",
    "validation_profile",
    "result",
    "summary",
    "cases",
    "reproduction"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "suite": { "type": "string", "minLength": 1 },
    "validation_profile": { "type": "string", "minLength": 1 },
    "result": { "enum": ["pass", "fail"] },
    "summary": {
      "type": "object",
      "required": ["cases", "passed", "failed"],
      "properties": {
        "cases": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "project",
          "expect",
          "actual",
          "result",
          "required_findings",
          "matched_findings",
          "blocking_limitations",
          "report",
          "messages"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "project": { "type": "string", "minLength": 1 },
          "expect": { "enum": ["pass", "fail"] },
          "actual": { "enum": ["pass", "fail"] },
          "result": { "enum": ["pass", "fail"] },
          "required_findings": {
            "type": "array",
            "items": { "$ref": "#/$defs/finding_expectation" }
          },
          "matched_findings": {
            "type": "array",
            "items": { "$ref": "#/$defs/finding_expectation" }
          },
          "blocking_limitations": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "report": { "type": "string", "minLength": 1 },
          "messages": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "reproduction": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "finding_expectation": {
      "type": "object",
      "required": ["id", "severity"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["critical", "warning", "info"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
