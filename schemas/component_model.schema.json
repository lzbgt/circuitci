{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://circuitci.local/schemas/component_model.schema.json",
  "title": "CircuitCI Component Model",
  "type": "object",
  "required": ["component_id", "version", "category", "ports", "model_quality"],
  "properties": {
    "component_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "ports": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind": {
            "enum": [
              "electrical_power",
              "electrical_ground",
              "digital_electrical_input",
              "digital_electrical_output",
              "digital_electrical_io",
              "passive"
            ]
          },
          "required": { "type": "boolean" },
          "electrical": {
            "type": "object",
            "properties": {
              "operating_voltage_min_V": { "type": "number" },
              "operating_voltage_max_V": { "type": "number" },
              "max_supply_current_A": { "type": "number", "minimum": 0 },
              "vih_min_V": { "type": "number" },
              "vil_max_V": { "type": "number" },
              "injection_current_limit_A": { "type": "number", "exclusiveMinimum": 0 },
              "drive_high_voltage_V": { "type": "number" },
              "source_impedance_ohm": { "type": "number", "exclusiveMinimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      }
    },
    "power_conversion": {
      "type": "object",
      "required": ["input_pin", "output_pin"],
      "properties": {
        "input_pin": { "type": "string", "minLength": 1 },
        "output_pin": { "type": "string", "minLength": 1 },
        "dropout_voltage_V": { "type": "number", "minimum": 0 },
        "max_output_current_A": { "type": "number", "minimum": 0 },
        "startup_delay_us": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "power_switch": {
      "type": "object",
      "required": ["input_pin", "output_pin", "control_pin", "enabled_state"],
      "properties": {
        "input_pin": { "type": "string", "minLength": 1 },
        "output_pin": { "type": "string", "minLength": 1 },
        "control_pin": { "type": "string", "minLength": 1 },
        "enabled_state": { "enum": ["high", "low"] },
        "max_output_current_A": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "battery_charger": {
      "type": "object",
      "required": ["input_pin", "battery_pin"],
      "properties": {
        "input_pin": { "type": "string", "minLength": 1 },
        "battery_pin": { "type": "string", "minLength": 1 },
        "charge_current_parameter": { "type": "string", "minLength": 1 },
        "min_charge_current_A": { "type": "number", "minimum": 0 },
        "max_charge_current_A": { "type": "number", "minimum": 0 },
        "regulation_voltage_V": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "power_mux": {
      "type": "object",
      "required": ["output_pin", "inputs"],
      "properties": {
        "output_pin": { "type": "string", "minLength": 1 },
        "selected_input_parameter": { "type": "string", "minLength": 1 },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "input_pin"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "input_pin": { "type": "string", "minLength": 1 },
              "reverse_blocking": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "signal_conditioning": {
      "type": "object",
      "properties": {
        "channels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "kind", "side_a_pin", "side_b_pin"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "kind": { "enum": ["level_shifter", "protection", "series_resistor", "bus_switch"] },
              "side_a_pin": { "type": "string", "minLength": 1 },
              "side_b_pin": { "type": "string", "minLength": 1 },
              "side_a_supply_pin": { "type": "string", "minLength": 1 },
              "side_b_supply_pin": { "type": "string", "minLength": 1 },
              "direction": { "enum": ["a_to_b", "b_to_a", "bidirectional"] },
              "unpowered_isolation": { "type": "boolean" },
              "enable_pin": { "type": "string", "minLength": 1 },
              "disabled_state": { "enum": ["high", "low", "z"] }
            },
            "additionalProperties": false
          }
        },
        "supply_constraints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "relation", "lower_supply_pin", "upper_supply_pin"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "relation": { "enum": ["less_than_or_equal"] },
              "lower_supply_pin": { "type": "string", "minLength": 1 },
              "upper_supply_pin": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "model_faces": { "type": "object" },
    "datasheet": {
      "type": "object",
      "required": ["manufacturer", "part_number", "documents"],
      "properties": {
        "manufacturer": { "type": "string", "minLength": 1 },
        "part_number": { "type": "string", "minLength": 1 },
        "package": { "type": "string", "minLength": 1 },
        "polarity": { "type": "string", "minLength": 1 },
        "pinout": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "absolute_maximum_ratings": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/datasheet_quantity" }
        },
        "safe_operating_area": {
          "type": "object",
          "properties": {
            "vds_id_curves": {
              "type": "array",
              "items": { "$ref": "#/$defs/soa_curve" }
            }
          },
          "additionalProperties": false
        },
        "electrical_characteristics": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "conditions": { "type": "string", "minLength": 1 },
              "min": { "type": "number" },
              "typ": { "type": "number" },
              "max": { "type": "number" },
              "unit": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "device_parameters": {
          "type": "object",
          "description": "Datasheet parameters that materially affect analog simulation, such as MOSFET Qg/Ciss/Coss/Crss/Rds(on), BJT capacitance/storage/gain/saturation, diode recovery/capacitance, and thermal limits.",
          "additionalProperties": {
            "type": "object",
            "required": ["unit"],
            "properties": {
              "conditions": { "type": "string", "minLength": 1 },
              "min": { "type": "number" },
              "typ": { "type": "number" },
              "max": { "type": "number" },
              "value": { "type": "number" },
              "unit": { "type": "string", "minLength": 1 },
              "simulation_relevance": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "documents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["title", "path", "source_url", "sha256"],
            "properties": {
              "title": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "source_url": { "type": "string", "minLength": 1 },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-fA-F]{64}$"
              },
              "retrieved": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "simulation": {
      "type": "object",
      "properties": {
        "spice": {
          "type": "object",
          "required": ["model_name", "model_type", "model_path", "provenance"],
          "properties": {
            "model_name": { "type": "string", "minLength": 1 },
            "model_type": { "enum": ["bjt_npn", "bjt_pnp", "mosfet_n", "mosfet_p", "diode", "subckt"] },
            "model_path": { "type": "string", "minLength": 1 },
            "provenance": { "enum": ["datasheet_fit", "vendor_model", "measured_fit", "estimated"] },
            "body_pin_policy": {
              "enum": ["require_explicit_body_pin", "tie_to_source_when_absent"]
            },
            "pin_order": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "valid_operating_notes": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "behavior": {
      "type": "object",
      "properties": {
        "reset": {
          "type": "object",
          "properties": {
            "pin": { "type": "string", "minLength": 1 },
            "active": { "enum": ["low", "high"] },
            "min_assert_us": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "boot": {
          "type": "object",
          "properties": {
            "sample_time_after_reset_release_us": { "type": "number", "minimum": 0 },
            "modes": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": ["straps"],
                "properties": {
                  "straps": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["pin", "required_state"],
                      "properties": {
                        "pin": { "type": "string", "minLength": 1 },
                        "required_state": { "type": "string", "minLength": 1 }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "bootloader": {
          "type": "object",
          "properties": {
            "interfaces": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": ["rx_pin", "sync_byte", "ack_byte"],
                "properties": {
                  "rx_pin": { "type": "string", "minLength": 1 },
                  "tx_pin": { "type": "string", "minLength": 1 },
                  "sync_byte": { "type": "integer", "minimum": 0, "maximum": 255 },
                  "ack_byte": { "type": "integer", "minimum": 0, "maximum": 255 }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "protocols": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "transport_interface": { "type": "string", "minLength": 1 },
              "frame": {
                "type": "object",
                "properties": {
                  "magic": {
                    "type": "array",
                    "items": { "type": "integer", "minimum": 0, "maximum": 255 }
                  },
                  "version": { "type": "integer", "minimum": 0 },
                  "request_type": { "type": "integer", "minimum": 0 },
                  "response_type": { "type": "integer", "minimum": 0 },
                  "crc": { "type": "string", "minLength": 1 },
                  "max_payload_len": { "type": "integer", "minimum": 0 },
                  "ok_result": { "type": "integer", "minimum": 0 }
                },
                "additionalProperties": false
              },
              "operations": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "required": ["opcode"],
                  "properties": {
                    "opcode": { "type": "integer", "minimum": 0 },
                    "role": { "type": "string", "minLength": 1 },
                    "payload": {
                      "type": "object",
                      "properties": {
                        "kind": { "type": "string", "minLength": 1 },
                        "min_len": { "type": "integer", "minimum": 0 },
                        "max_len": { "type": "integer", "minimum": 0 },
                        "len": { "type": "integer", "minimum": 0 },
                        "overhead_len": { "type": "integer", "minimum": 0 },
                        "values": {
                          "type": "object",
                          "additionalProperties": { "type": "integer", "minimum": 0 }
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              },
              "flows": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "phases": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["operation"],
                        "properties": {
                          "operation": { "type": "string", "minLength": 1 },
                          "repeat": { "enum": ["zero_or_more", "one_or_more"] }
                        },
                        "additionalProperties": false
                      }
                    },
                    "final_state": { "type": "string", "minLength": 1 }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "model_quality": {
      "type": "object",
      "required": ["source", "confidence", "intended_use", "not_valid_for"],
      "properties": {
        "source": { "enum": ["datasheet", "measured", "estimated", "generic"] },
        "confidence": { "enum": ["high", "medium", "low"] },
        "intended_use": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "not_valid_for": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "datasheet_quantity": {
      "type": "object",
      "required": ["value", "unit"],
      "properties": {
        "value": { "type": "number" },
        "unit": { "type": "string", "minLength": 1 },
        "conditions": { "type": "string", "minLength": 1 },
        "reference_temperature_c": { "type": "number" },
        "derate_above_c": { "type": "number" },
        "derating_per_c": { "type": "number", "exclusiveMinimum": 0 },
        "derating_basis": { "type": "string", "minLength": 1 },
        "pulse_width_us": { "type": "number", "exclusiveMinimum": 0 },
        "duty_cycle_max": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "soa_curve": {
      "type": "object",
      "required": [
        "name",
        "pulse_width_us",
        "duty_cycle_max",
        "source_document",
        "source_figure",
        "digitization",
        "points"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "pulse_width_us": { "type": "number", "exclusiveMinimum": 0 },
        "duty_cycle_max": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "temperature_c": { "type": "number" },
        "source_document": { "type": "string", "minLength": 1 },
        "source_figure": { "type": "string", "minLength": 1 },
        "digitization": {
          "type": "object",
          "required": ["method", "confidence"],
          "properties": {
            "method": { "type": "string", "minLength": 1 },
            "confidence": { "type": "string", "minLength": 1 },
            "note": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "points": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["vds_v", "id_a"],
            "properties": {
              "vds_v": { "type": "number", "exclusiveMinimum": 0 },
              "id_a": { "type": "number", "exclusiveMinimum": 0 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
