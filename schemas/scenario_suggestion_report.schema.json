{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://circuitci.local/schemas/scenario_suggestion_report.schema.json",
  "title": "CircuitCI Scenario Suggestion Report",
  "type": "object",
  "required": ["schema_version", "project", "suggestions"],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "project": { "type": "string", "minLength": 1 },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "confidence",
          "runnable",
          "reason",
          "scenario"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "confidence": { "enum": ["low", "medium", "high"] },
          "runnable": { "type": "boolean" },
          "reason": { "type": "string", "minLength": 1 },
          "required_inputs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "scenario": {
            "type": "object",
            "required": ["name", "type", "checks"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 },
              "checks": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "parameters": {
                "type": "object",
                "additionalProperties": {
                  "anyOf": [
                    { "type": "string" },
                    { "type": "number" },
                    { "type": "boolean" },
                    { "type": "null" }
                  ]
                }
              },
              "target": {
                "type": "object",
                "required": ["component"],
                "properties": {
                  "component": { "type": "string", "minLength": 1 },
                  "power_pin": { "type": "string", "minLength": 1 },
                  "reset_pin": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              },
              "timing": {
                "type": "object",
                "required": ["power_valid_at_us"],
                "properties": {
                  "power_valid_at_us": { "type": "number", "minimum": 0 },
                  "reset_release_delay_us": { "type": "number", "minimum": 0 },
                  "reset_release_at_us": { "type": "number", "minimum": 0 },
                  "boot_sample_at_us": { "type": "number", "minimum": 0 }
                },
                "additionalProperties": false
              },
              "required_boot_mode": { "type": "string", "minLength": 1 },
              "straps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["component", "pin"],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "pin": { "type": "string", "minLength": 1 },
                    "net": { "type": "string", "minLength": 1 },
                    "actual": { "type": "string", "minLength": 1 }
                  },
                  "additionalProperties": false
                }
              },
              "bootloader": {
                "type": "object",
                "required": [
                  "component",
                  "interface",
                  "sync_byte",
                  "expected_response"
                ],
                "properties": {
                  "component": { "type": "string", "minLength": 1 },
                  "interface": { "type": "string", "minLength": 1 },
                  "sync_byte": { "type": "integer", "minimum": 0, "maximum": 255 },
                  "expected_response": { "type": "integer", "minimum": 0, "maximum": 255 }
                },
                "additionalProperties": false
              },
              "events": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["action", "bytes"],
                  "properties": {
                    "at_us": { "type": "number", "minimum": 0 },
                    "action": { "type": "string", "minLength": 1 },
                    "from": { "$ref": "#/$defs/endpoint" },
                    "to": { "$ref": "#/$defs/endpoint" },
                    "bytes": {
                      "type": "array",
                      "items": { "type": "integer", "minimum": 0, "maximum": 255 }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "conditioning": {
                "type": "object",
                "required": ["component", "channel", "kind", "side_a", "side_b"],
                "properties": {
                  "component": { "type": "string", "minLength": 1 },
                  "channel": { "type": "string", "minLength": 1 },
                  "kind": { "enum": ["level_shifter", "protection", "series_resistor", "bus_switch"] },
                  "side_a": { "$ref": "#/$defs/conditioning_side" },
                  "side_b": { "$ref": "#/$defs/conditioning_side" },
                  "direction": { "enum": ["a_to_b", "b_to_a", "bidirectional"] },
                  "unpowered_isolation": { "type": "boolean" }
                },
                "additionalProperties": false
              },
              "protection_clamps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "component",
                    "clamp",
                    "protected_pin",
                    "protected_net",
                    "reference_pin",
                    "reference_net",
                    "reference"
                  ],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "clamp": { "type": "string", "minLength": 1 },
                    "protected_pin": { "type": "string", "minLength": 1 },
                    "protected_net": { "type": "string", "minLength": 1 },
                    "reference_pin": { "type": "string", "minLength": 1 },
                    "reference_net": { "type": "string", "minLength": 1 },
                    "reference": { "enum": ["ground", "power"] },
                    "working_voltage_max_V": { "type": "number", "exclusiveMinimum": 0 },
                    "line_capacitance_F": { "type": "number", "minimum": 0 },
                    "placement": { "$ref": "#/$defs/placement" },
                    "distance_to_target_mm": { "type": "number", "minimum": 0 }
                  },
                  "additionalProperties": false
                }
              },
              "usb_connectors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "component",
                    "standard",
                    "vbus_pin",
                    "dp_pin",
                    "dp_net",
                    "dm_pin",
                    "dm_net",
                    "gnd_pin",
                    "gnd_net"
                  ],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "standard": { "type": "string", "minLength": 1 },
                    "vbus_pin": { "type": "string", "minLength": 1 },
                    "vbus_net": { "type": "string", "minLength": 1 },
                    "dp_pin": { "type": "string", "minLength": 1 },
                    "dp_net": { "type": "string", "minLength": 1 },
                    "dm_pin": { "type": "string", "minLength": 1 },
                    "dm_net": { "type": "string", "minLength": 1 },
                    "gnd_pin": { "type": "string", "minLength": 1 },
                    "gnd_net": { "type": "string", "minLength": 1 },
                    "shield_pin": { "type": "string", "minLength": 1 },
                    "shield_net": { "type": "string", "minLength": 1 },
                    "placement": { "$ref": "#/$defs/placement" },
                    "footprint": { "$ref": "#/$defs/footprint" },
                    "nearest_board_edge": { "$ref": "#/$defs/board_edge" },
                    "nearest_component_clearance": { "$ref": "#/$defs/component_clearance" },
                    "entry_clearance": { "$ref": "#/$defs/entry_clearance" }
                  },
                  "additionalProperties": false
                }
              },
              "usb_routes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "signal",
                    "net",
                    "route_length_mm",
                    "via_count"
                  ],
                  "properties": {
                    "signal": { "enum": ["D+", "D-", "VBUS"] },
                    "net": { "type": "string", "minLength": 1 },
                    "route_length_mm": { "type": "number", "minimum": 0 },
                    "via_count": { "type": "integer", "minimum": 0 },
                    "expected_data_line_width_mm": { "type": "number", "exclusiveMinimum": 0 },
                    "measured_data_line_width_mm": { "type": "number", "exclusiveMinimum": 0 },
                    "data_line_width_delta_mm": { "type": "number", "minimum": 0 },
                    "expected_vbus_route_width_mm": { "type": "number", "exclusiveMinimum": 0 },
                    "measured_vbus_route_width_min_mm": { "type": "number", "exclusiveMinimum": 0 },
                    "protection_component": { "type": "string", "minLength": 1 },
                    "connector_pad": { "$ref": "#/$defs/usb_route_pad" },
                    "protection_pad": { "$ref": "#/$defs/usb_route_pad" },
                    "connector_pad_to_route_distance_mm": { "type": "number", "minimum": 0 },
                    "protection_pad_to_route_distance_mm": { "type": "number", "minimum": 0 },
                    "connector_to_protection_pad_route_distance_mm": { "type": "number", "minimum": 0 },
                    "unreferenced_route_length_mm": { "type": "number", "minimum": 0 },
                    "unreferenced_segments": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "segment_index",
                          "segment_length_mm",
                          "midpoint_x_mm",
                          "midpoint_y_mm",
                          "layer"
                        ],
                        "properties": {
                          "segment_index": { "type": "integer", "minimum": 0 },
                          "segment_length_mm": { "type": "number", "minimum": 0 },
                          "midpoint_x_mm": { "type": "number" },
                          "midpoint_y_mm": { "type": "number" },
                          "layer": { "type": "string", "minLength": 1 }
                        },
                        "additionalProperties": false
                      }
                    },
                    "filled_unreferenced_route_length_mm": { "type": "number", "minimum": 0 },
                    "filled_unreferenced_segments": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "segment_index",
                          "segment_length_mm",
                          "midpoint_x_mm",
                          "midpoint_y_mm",
                          "layer"
                        ],
                        "properties": {
                          "segment_index": { "type": "integer", "minimum": 0 },
                          "segment_length_mm": { "type": "number", "minimum": 0 },
                          "midpoint_x_mm": { "type": "number" },
                          "midpoint_y_mm": { "type": "number" },
                          "layer": { "type": "string", "minLength": 1 }
                        },
                        "additionalProperties": false
                      }
                    },
                    "filled_zone_edge_clearance_min_mm": { "type": "number", "minimum": 0 },
                    "filled_zone_edge_clearance_segments": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "segment_index",
                          "segment_length_mm",
                          "midpoint_x_mm",
                          "midpoint_y_mm",
                          "layer"
                        ],
                        "properties": {
                          "segment_index": { "type": "integer", "minimum": 0 },
                          "segment_length_mm": { "type": "number", "minimum": 0 },
                          "midpoint_x_mm": { "type": "number" },
                          "midpoint_y_mm": { "type": "number" },
                          "layer": { "type": "string", "minLength": 1 },
                          "filled_zone_edge_clearance_mm": { "type": "number", "minimum": 0 }
                        },
                        "additionalProperties": false
                      }
                    },
                    "ground_zone_contacts": {
                      "type": "array",
                      "items": { "$ref": "#/$defs/usb_ground_zone_contact" }
                    },
                    "filled_ground_zone_contacts": {
                      "type": "array",
                      "items": { "$ref": "#/$defs/usb_ground_zone_contact" }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "usb_route_pairs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "dp_net",
                    "dm_net",
                    "dp_route_length_mm",
                    "dm_route_length_mm",
                    "data_pair_length_mismatch_mm",
                    "dp_via_count",
                    "dm_via_count",
                    "data_pair_via_count_delta"
                  ],
                  "properties": {
                    "dp_net": { "type": "string", "minLength": 1 },
                    "dm_net": { "type": "string", "minLength": 1 },
                    "dp_route_length_mm": { "type": "number", "minimum": 0 },
                    "dm_route_length_mm": { "type": "number", "minimum": 0 },
                    "data_pair_length_mismatch_mm": { "type": "number", "minimum": 0 },
                    "dp_via_count": { "type": "integer", "minimum": 0 },
                    "dm_via_count": { "type": "integer", "minimum": 0 },
                    "data_pair_via_count_delta": { "type": "integer", "minimum": 0 },
                    "expected_data_pair_gap_mm": { "type": "number", "exclusiveMinimum": 0 },
                    "measured_data_pair_gap_mm": { "type": "number" },
                    "data_pair_gap_delta_mm": { "type": "number", "minimum": 0 }
                  },
                  "additionalProperties": false
                }
              },
              "clocks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "component",
                    "name",
                    "input_pin",
                    "input_net",
                    "output_pin",
                    "output_net"
                  ],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "name": { "type": "string", "minLength": 1 },
                    "input_pin": { "type": "string", "minLength": 1 },
                    "input_net": { "type": "string", "minLength": 1 },
                    "output_pin": { "type": "string", "minLength": 1 },
                    "output_net": { "type": "string", "minLength": 1 },
                    "crystal_component": { "type": "string", "minLength": 1 }
                  },
                  "additionalProperties": false
                }
              },
              "reset_supervisors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "component",
                    "monitored_pin",
                    "monitored_net",
                    "reset_output_pin",
                    "reset_net",
                    "threshold_min_V",
                    "threshold_max_V"
                  ],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "monitored_pin": { "type": "string", "minLength": 1 },
                    "monitored_net": { "type": "string", "minLength": 1 },
                    "reset_output_pin": { "type": "string", "minLength": 1 },
                    "reset_net": { "type": "string", "minLength": 1 },
                    "threshold_min_V": { "type": "number", "exclusiveMinimum": 0 },
                    "threshold_max_V": { "type": "number", "exclusiveMinimum": 0 }
                  },
                  "additionalProperties": false
                }
              },
              "regulators": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "component",
                    "input_pin",
                    "input_net",
                    "output_pin",
                    "output_net"
                  ],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "input_pin": { "type": "string", "minLength": 1 },
                    "input_net": { "type": "string", "minLength": 1 },
                    "output_pin": { "type": "string", "minLength": 1 },
                    "output_net": { "type": "string", "minLength": 1 },
                    "dropout_voltage_V": { "type": "number", "minimum": 0 },
                    "min_output_current_A": { "type": "number", "minimum": 0 },
                    "max_output_current_A": { "type": "number", "minimum": 0 },
                    "startup_delay_us": { "type": "number", "minimum": 0 },
                    "input_capacitance_min_F": { "type": "number", "exclusiveMinimum": 0 },
                    "output_capacitance_min_F": { "type": "number", "exclusiveMinimum": 0 },
                    "input_support_capacitance_F": { "type": "number", "minimum": 0 },
                    "input_support_capacitors": {
                      "type": "array",
                      "items": { "type": "string", "minLength": 1 }
                    },
                    "output_support_capacitance_F": { "type": "number", "minimum": 0 },
                    "output_support_capacitors": {
                      "type": "array",
                      "items": { "type": "string", "minLength": 1 }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "pin_states": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["component", "pin", "mode"],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "pin": { "type": "string", "minLength": 1 },
                    "mode": { "enum": ["input", "output", "high_z"] },
                    "state": { "enum": ["high", "low", "z"] }
                  },
                  "additionalProperties": false
                }
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["driver", "victim", "series_resistance_ohm"],
                  "properties": {
                    "driver": { "$ref": "#/$defs/endpoint" },
                    "victim": { "$ref": "#/$defs/endpoint" },
                    "net": { "type": "string", "minLength": 1 },
                    "series_resistance_ohm": { "type": "number", "minimum": 0 }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "endpoint": {
      "type": "object",
      "required": ["component", "pin"],
      "properties": {
        "component": { "type": "string", "minLength": 1 },
        "pin": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "conditioning_side": {
      "type": "object",
      "required": ["pin", "net"],
      "properties": {
        "pin": { "type": "string", "minLength": 1 },
        "net": { "type": "string", "minLength": 1 },
        "supply_pin": { "type": "string", "minLength": 1 },
        "supply_net": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "placement": {
      "type": "object",
      "required": ["x_mm", "y_mm"],
      "properties": {
        "x_mm": { "type": "number" },
        "y_mm": { "type": "number" },
        "side": { "enum": ["top", "bottom"] },
        "rotation_deg": { "type": "number" }
      },
      "additionalProperties": false
    },
    "layout_point": {
      "type": "object",
      "required": ["x_mm", "y_mm"],
      "properties": {
        "x_mm": { "type": "number" },
        "y_mm": { "type": "number" }
      },
      "additionalProperties": false
    },
    "board_edge": {
      "type": "object",
      "required": [
        "start",
        "end",
        "distance_to_connector_mm",
        "connector_edge_reference",
        "edge_angle_deg",
        "outward_normal_deg",
        "connector_rotation_error_deg"
      ],
      "properties": {
        "start": { "$ref": "#/$defs/layout_point" },
        "end": { "$ref": "#/$defs/layout_point" },
        "layer": { "type": "string", "minLength": 1 },
        "source_primitive": {
          "enum": ["gr_line", "gr_circle", "gr_arc"]
        },
        "source_primitive_index": { "type": "integer", "minimum": 0 },
        "sample_index": { "type": "integer", "minimum": 0 },
        "sample_count": { "type": "integer", "minimum": 1 },
        "contour_index": { "type": "integer", "minimum": 0 },
        "boundary_role": { "enum": ["external", "cutout", "unknown"] },
        "distance_to_connector_mm": { "type": "number", "minimum": 0 },
        "connector_edge_reference": {
          "type": "string",
          "enum": [
            "placement_center",
            "footprint_segment",
            "footprint_rectangle",
            "footprint_polygon",
            "footprint_circle",
            "footprint_arc"
          ]
        },
        "footprint_graphic_layer": { "type": "string", "minLength": 1 },
        "footprint_graphic_kind": { "type": "string", "minLength": 1 },
        "connector_body_overhang_mm": { "type": "number", "minimum": 0 },
        "edge_angle_deg": { "type": "number" },
        "outward_normal_deg": { "type": "number" },
        "expected_connector_rotation_deg": { "type": "number" },
        "connector_entry_direction_offset_deg": { "type": "number" },
        "connector_rotation_error_deg": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "component_clearance": {
      "type": "object",
      "required": [
        "component",
        "clearance_mm",
        "connector_clearance_reference",
        "component_clearance_reference"
      ],
      "properties": {
        "component": { "type": "string", "minLength": 1 },
        "clearance_mm": { "type": "number", "minimum": 0 },
        "connector_clearance_reference": {
          "$ref": "#/$defs/clearance_reference"
        },
        "connector_footprint_graphic_layer": { "type": "string", "minLength": 1 },
        "connector_footprint_graphic_kind": { "type": "string", "minLength": 1 },
        "component_clearance_reference": {
          "$ref": "#/$defs/clearance_reference"
        },
        "component_footprint_graphic_layer": { "type": "string", "minLength": 1 },
        "component_footprint_graphic_kind": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "entry_clearance": {
      "type": "object",
      "required": [
        "entry_direction_deg",
        "entry_direction_source",
        "entry_aperture_source",
        "connector_front_projection_mm",
        "entry_aperture_front_projection_mm",
        "entry_aperture_center_lateral_projection_mm"
      ],
      "properties": {
        "entry_direction_deg": { "type": "number" },
        "entry_direction_source": {
          "enum": ["placement_rotation", "component_model_offset"]
        },
        "entry_direction_offset_deg": { "type": "number" },
        "entry_aperture_source": {
          "enum": ["footprint_front", "component_model_aperture"]
        },
        "connector_front_projection_mm": { "type": "number" },
        "entry_aperture_front_projection_mm": { "type": "number" },
        "entry_aperture_center_lateral_projection_mm": { "type": "number" },
        "entry_aperture_front_offset_mm": { "type": "number" },
        "entry_aperture_lateral_offset_mm": { "type": "number" },
        "entry_aperture_width_mm": { "type": "number" },
        "model_min_cable_entry_clearance_width_mm": { "type": "number" },
        "nearest_obstruction": { "$ref": "#/$defs/entry_obstruction" }
      },
      "additionalProperties": false
    },
    "entry_obstruction": {
      "type": "object",
      "required": [
        "component",
        "obstruction_depth_mm",
        "obstruction_lateral_offset_mm",
        "obstruction_reference"
      ],
      "properties": {
        "component": { "type": "string", "minLength": 1 },
        "obstruction_depth_mm": { "type": "number", "minimum": 0 },
        "obstruction_lateral_offset_mm": { "type": "number" },
        "obstruction_reference": { "$ref": "#/$defs/clearance_reference" },
        "obstruction_footprint_graphic_layer": { "type": "string", "minLength": 1 },
        "obstruction_footprint_graphic_kind": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "clearance_reference": {
      "type": "string",
      "enum": [
        "placement_center",
        "footprint_segment",
        "footprint_rectangle",
        "footprint_polygon",
        "footprint_circle",
        "footprint_arc"
      ]
    },
    "footprint": {
      "type": "object",
      "properties": {
        "segments": {
          "type": "array",
          "items": { "$ref": "#/$defs/footprint_graphic" }
        },
        "rectangles": {
          "type": "array",
          "items": { "$ref": "#/$defs/footprint_graphic" }
        },
        "polygons": {
          "type": "array",
          "items": { "$ref": "#/$defs/footprint_polygon" }
        },
        "circles": {
          "type": "array",
          "items": { "$ref": "#/$defs/footprint_circle" }
        },
        "arcs": {
          "type": "array",
          "items": { "$ref": "#/$defs/footprint_arc" }
        }
      },
      "additionalProperties": false
    },
    "footprint_graphic": {
      "type": "object",
      "required": ["start", "end", "layer", "kind"],
      "properties": {
        "start": { "$ref": "#/$defs/layout_point" },
        "end": { "$ref": "#/$defs/layout_point" },
