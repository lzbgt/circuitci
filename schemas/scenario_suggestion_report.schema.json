{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://circuitci.local/schemas/scenario_suggestion_report.schema.json",
  "title": "CircuitCI Scenario Suggestion Report",
  "type": "object",
  "required": ["schema_version", "project", "suggestions"],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "project": { "type": "string", "minLength": 1 },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "confidence",
          "runnable",
          "reason",
          "scenario"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "confidence": { "enum": ["low", "medium", "high"] },
          "runnable": { "type": "boolean" },
          "reason": { "type": "string", "minLength": 1 },
          "required_inputs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "scenario": {
            "type": "object",
            "required": ["name", "type", "checks"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 },
              "checks": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "target": {
                "type": "object",
                "required": ["component"],
                "properties": {
                  "component": { "type": "string", "minLength": 1 },
                  "power_pin": { "type": "string", "minLength": 1 },
                  "reset_pin": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              },
              "timing": {
                "type": "object",
                "required": ["power_valid_at_us"],
                "properties": {
                  "power_valid_at_us": { "type": "number", "minimum": 0 },
                  "reset_release_delay_us": { "type": "number", "minimum": 0 },
                  "reset_release_at_us": { "type": "number", "minimum": 0 },
                  "boot_sample_at_us": { "type": "number", "minimum": 0 }
                },
                "additionalProperties": false
              },
              "required_boot_mode": { "type": "string", "minLength": 1 },
              "straps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["component", "pin"],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "pin": { "type": "string", "minLength": 1 },
                    "net": { "type": "string", "minLength": 1 },
                    "actual": { "type": "string", "minLength": 1 }
                  },
                  "additionalProperties": false
                }
              },
              "bootloader": {
                "type": "object",
                "required": [
                  "component",
                  "interface",
                  "sync_byte",
                  "expected_response"
                ],
                "properties": {
                  "component": { "type": "string", "minLength": 1 },
                  "interface": { "type": "string", "minLength": 1 },
                  "sync_byte": { "type": "integer", "minimum": 0, "maximum": 255 },
                  "expected_response": { "type": "integer", "minimum": 0, "maximum": 255 }
                },
                "additionalProperties": false
              },
              "events": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["action", "bytes"],
                  "properties": {
                    "at_us": { "type": "number", "minimum": 0 },
                    "action": { "type": "string", "minLength": 1 },
                    "from": { "$ref": "#/$defs/endpoint" },
                    "to": { "$ref": "#/$defs/endpoint" },
                    "bytes": {
                      "type": "array",
                      "items": { "type": "integer", "minimum": 0, "maximum": 255 }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "conditioning": {
                "type": "object",
                "required": ["component", "channel", "kind", "side_a", "side_b"],
                "properties": {
                  "component": { "type": "string", "minLength": 1 },
                  "channel": { "type": "string", "minLength": 1 },
                  "kind": { "enum": ["level_shifter", "protection", "series_resistor", "bus_switch"] },
                  "side_a": { "$ref": "#/$defs/conditioning_side" },
                  "side_b": { "$ref": "#/$defs/conditioning_side" },
                  "direction": { "enum": ["a_to_b", "b_to_a", "bidirectional"] },
                  "unpowered_isolation": { "type": "boolean" }
                },
                "additionalProperties": false
              },
              "clocks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "component",
                    "name",
                    "input_pin",
                    "input_net",
                    "output_pin",
                    "output_net"
                  ],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "name": { "type": "string", "minLength": 1 },
                    "input_pin": { "type": "string", "minLength": 1 },
                    "input_net": { "type": "string", "minLength": 1 },
                    "output_pin": { "type": "string", "minLength": 1 },
                    "output_net": { "type": "string", "minLength": 1 },
                    "crystal_component": { "type": "string", "minLength": 1 }
                  },
                  "additionalProperties": false
                }
              },
              "reset_supervisors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "component",
                    "monitored_pin",
                    "monitored_net",
                    "reset_output_pin",
                    "reset_net",
                    "threshold_min_V",
                    "threshold_max_V"
                  ],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "monitored_pin": { "type": "string", "minLength": 1 },
                    "monitored_net": { "type": "string", "minLength": 1 },
                    "reset_output_pin": { "type": "string", "minLength": 1 },
                    "reset_net": { "type": "string", "minLength": 1 },
                    "threshold_min_V": { "type": "number", "exclusiveMinimum": 0 },
                    "threshold_max_V": { "type": "number", "exclusiveMinimum": 0 }
                  },
                  "additionalProperties": false
                }
              },
              "regulators": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "component",
                    "input_pin",
                    "input_net",
                    "output_pin",
                    "output_net"
                  ],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "input_pin": { "type": "string", "minLength": 1 },
                    "input_net": { "type": "string", "minLength": 1 },
                    "output_pin": { "type": "string", "minLength": 1 },
                    "output_net": { "type": "string", "minLength": 1 },
                    "dropout_voltage_V": { "type": "number", "minimum": 0 },
                    "max_output_current_A": { "type": "number", "minimum": 0 },
                    "startup_delay_us": { "type": "number", "minimum": 0 },
                    "input_capacitance_min_F": { "type": "number", "exclusiveMinimum": 0 },
                    "output_capacitance_min_F": { "type": "number", "exclusiveMinimum": 0 }
                  },
                  "additionalProperties": false
                }
              },
              "pin_states": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["component", "pin", "mode"],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "pin": { "type": "string", "minLength": 1 },
                    "mode": { "enum": ["input", "output", "high_z"] },
                    "state": { "enum": ["high", "low", "z"] }
                  },
                  "additionalProperties": false
                }
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["driver", "victim", "series_resistance_ohm"],
                  "properties": {
                    "driver": { "$ref": "#/$defs/endpoint" },
                    "victim": { "$ref": "#/$defs/endpoint" },
                    "net": { "type": "string", "minLength": 1 },
                    "series_resistance_ohm": { "type": "number", "minimum": 0 }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "endpoint": {
      "type": "object",
      "required": ["component", "pin"],
      "properties": {
        "component": { "type": "string", "minLength": 1 },
        "pin": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "conditioning_side": {
      "type": "object",
      "required": ["pin", "net"],
      "properties": {
        "pin": { "type": "string", "minLength": 1 },
        "net": { "type": "string", "minLength": 1 },
        "supply_pin": { "type": "string", "minLength": 1 },
        "supply_net": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
