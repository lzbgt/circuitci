{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://circuitci.local/schemas/board_ir.schema.json",
  "title": "CircuitCI Board IR Project",
  "type": "object",
  "required": ["project", "board"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "import_source": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "libraries": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "board": {
      "type": "object",
      "required": ["components", "nets"],
      "properties": {
        "components": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["model", "pins"],
            "properties": {
              "model": { "type": "string", "minLength": 1 },
              "part_number": { "type": "string" },
              "power_domain": { "type": "string" },
              "power_domains": {
                "type": "object",
                "additionalProperties": { "type": "string", "minLength": 1 }
              },
              "pins": {
                "type": "object",
                "additionalProperties": { "type": "string", "minLength": 1 }
              },
              "parameters": {
                "type": "object",
                "additionalProperties": true
              },
              "source": {
                "type": "object",
                "properties": {
                  "board_pin_electrical_types": {
                    "type": "object",
                    "additionalProperties": { "type": "string", "minLength": 1 }
                  }
                },
                "additionalProperties": true
              },
              "spice": {
                "type": "object",
                "required": ["primitive"],
                "properties": {
                  "primitive": {
                    "enum": [
                      "resistor",
                      "capacitor",
                      "inductor",
                      "dc_voltage_source",
                      "pulse_voltage_source"
                    ]
                  },
                  "value_ohm": { "type": "number", "exclusiveMinimum": 0 },
                  "value_f": { "type": "number", "exclusiveMinimum": 0 },
                  "value_h": { "type": "number", "exclusiveMinimum": 0 },
                  "dc_v": { "type": "number" },
                  "pulse": {
                    "type": "object",
                    "required": [
                      "initial_v",
                      "pulsed_v",
                      "delay_us",
                      "rise_us",
                      "fall_us",
                      "width_us",
                      "period_us"
                    ],
                    "properties": {
                      "initial_v": { "type": "number" },
                      "pulsed_v": { "type": "number" },
                      "delay_us": { "type": "number", "minimum": 0 },
                      "rise_us": { "type": "number", "minimum": 0 },
                      "fall_us": { "type": "number", "minimum": 0 },
                      "width_us": { "type": "number", "exclusiveMinimum": 0 },
                      "period_us": { "type": "number", "exclusiveMinimum": 0 }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": true
          }
        },
        "nets": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": {
                "enum": ["power", "ground", "digital_or_analog"]
              },
              "nominal_voltage": { "type": "number" },
              "powered": { "type": "boolean" },
              "supply_current_limit_A": { "type": "number", "exclusiveMinimum": 0 },
              "power_valid_at_us": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": true
          }
        },
        "layout": {
          "type": "object",
          "properties": {
            "placements": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": ["x_mm", "y_mm"],
                "properties": {
                  "x_mm": { "type": "number" },
                  "y_mm": { "type": "number" },
                  "side": { "enum": ["top", "bottom"] },
                  "rotation_deg": { "type": "number" }
                },
                "additionalProperties": false
              }
            },
            "footprints": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "segments": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["start", "end", "layer", "kind"],
                      "properties": {
                        "start": { "$ref": "#/$defs/layout_point" },
                        "end": { "$ref": "#/$defs/layout_point" },
                        "layer": { "type": "string", "minLength": 1 },
                        "kind": { "type": "string", "minLength": 1 }
                      },
                      "additionalProperties": false
                    }
                  },
                  "rectangles": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["start", "end", "layer", "kind"],
                      "properties": {
                        "start": { "$ref": "#/$defs/layout_point" },
                        "end": { "$ref": "#/$defs/layout_point" },
                        "layer": { "type": "string", "minLength": 1 },
                        "kind": { "type": "string", "minLength": 1 }
                      },
                      "additionalProperties": false
                    }
                  },
                  "polygons": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["points", "layer", "kind"],
                      "properties": {
                        "points": {
                          "type": "array",
                          "minItems": 3,
                          "items": { "$ref": "#/$defs/layout_point" }
                        },
                        "layer": { "type": "string", "minLength": 1 },
                        "kind": { "type": "string", "minLength": 1 }
                      },
                      "additionalProperties": false
                    }
                  },
                  "circles": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["center", "end", "layer", "kind"],
                      "properties": {
                        "center": { "$ref": "#/$defs/layout_point" },
                        "end": { "$ref": "#/$defs/layout_point" },
                        "layer": { "type": "string", "minLength": 1 },
                        "kind": { "type": "string", "minLength": 1 }
                      },
                      "additionalProperties": false
                    }
                  },
                  "arcs": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["start", "mid", "end", "layer", "kind"],
                      "properties": {
                        "start": { "$ref": "#/$defs/layout_point" },
                        "mid": { "$ref": "#/$defs/layout_point" },
                        "end": { "$ref": "#/$defs/layout_point" },
                        "layer": { "type": "string", "minLength": 1 },
                        "kind": { "type": "string", "minLength": 1 }
                      },
                      "additionalProperties": false
                    }
                  },
                  "entry_direction": {
                    "type": "object",
                    "properties": {
                      "offset_deg": { "type": "number" },
                      "source": { "type": "string", "minLength": 1 }
                    },
                    "additionalProperties": false
                  },
                  "entry_clearance": {
                    "type": "object",
                    "properties": {
                      "depth_mm": { "type": "number", "exclusiveMinimum": 0 },
                      "width_mm": { "type": "number", "exclusiveMinimum": 0 },
                      "source": { "type": "string", "minLength": 1 }
                    },
                    "additionalProperties": false
                  },
                  "entry_aperture": {
                    "type": "object",
                    "properties": {
                      "front_offset_mm": { "type": "number" },
                      "lateral_offset_mm": { "type": "number" },
                      "width_mm": { "type": "number", "exclusiveMinimum": 0 },
                      "source": { "type": "string", "minLength": 1 }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              }
            },
            "outline": {
              "type": "object",
              "properties": {
                "segments": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["start", "end", "layer"],
                    "properties": {
                      "start": { "$ref": "#/$defs/layout_point" },
                      "end": { "$ref": "#/$defs/layout_point" },
                      "layer": { "type": "string", "minLength": 1 },
                      "source_primitive": {
                        "enum": ["gr_line", "gr_rect", "gr_poly", "gr_circle", "gr_arc"]
                      },
                      "source_primitive_index": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "sample_index": { "type": "integer", "minimum": 0 },
                      "sample_count": { "type": "integer", "minimum": 1 },
                      "contour_index": { "type": "integer", "minimum": 0 },
                      "boundary_role": {
                        "enum": ["external", "cutout", "unknown"]
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            },
            "pads": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "required": ["at", "net"],
                  "properties": {
                    "at": { "$ref": "#/$defs/layout_point" },
                    "net": { "type": "string", "minLength": 1 },
                    "layers": {
                      "type": "array",
                      "items": { "type": "string", "minLength": 1 }
                    },
                    "kind": { "type": "string", "minLength": 1 },
                    "shape": { "type": "string", "minLength": 1 },
                    "size": {
                      "type": "object",
                      "required": ["x_mm", "y_mm"],
                      "properties": {
                        "x_mm": { "type": "number", "exclusiveMinimum": 0 },
                        "y_mm": { "type": "number", "exclusiveMinimum": 0 }
                      },
                      "additionalProperties": false
                    },
                    "rotation_deg": { "type": "number" },
                    "drill_mm": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "routes": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "segments": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["start", "end", "width_mm", "layer"],
                      "properties": {
                        "start": { "$ref": "#/$defs/layout_point" },
                        "end": { "$ref": "#/$defs/layout_point" },
                        "width_mm": { "type": "number", "exclusiveMinimum": 0 },
                        "layer": { "type": "string", "minLength": 1 }
                      },
                      "additionalProperties": false
                    }
                  },
                  "vias": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["at", "size_mm", "drill_mm"],
                      "properties": {
                        "at": { "$ref": "#/$defs/layout_point" },
                        "size_mm": { "type": "number", "exclusiveMinimum": 0 },
                        "drill_mm": { "type": "number", "exclusiveMinimum": 0 },
                        "layers": {
                          "type": "array",
                          "items": { "type": "string", "minLength": 1 }
                        }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              }
            },
            "zones": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["layer", "polygon"],
                  "properties": {
                    "layer": { "type": "string", "minLength": 1 },
                    "polygon": {
                      "type": "array",
                      "minItems": 3,
                      "items": { "$ref": "#/$defs/layout_point" }
                    },
                    "filled_polygons": {
                      "type": "array",
                      "items": {
                        "type": "array",
                        "minItems": 3,
                        "items": { "$ref": "#/$defs/layout_point" }
                      }
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "constraints": {
              "type": "object",
              "properties": {
                "net_rules": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "properties": {
                      "net_class": { "type": "string", "minLength": 1 },
                      "track_width_mm": { "type": "number", "exclusiveMinimum": 0 },
                      "diff_pair_width_mm": { "type": "number", "exclusiveMinimum": 0 },
                      "diff_pair_gap_mm": { "type": "number", "exclusiveMinimum": 0 },
                      "length_max_mm": { "type": "number", "exclusiveMinimum": 0 },
                      "skew_max_mm": { "type": "number", "minimum": 0 }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "checks": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "parameters": { "type": "object" },
          "target": {
            "type": "object",
            "required": ["component"],
            "properties": {
              "component": { "type": "string", "minLength": 1 },
              "power_pin": { "type": "string", "minLength": 1 },
              "reset_pin": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "pin_states": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["component", "pin", "mode"],
              "properties": {
                "component": { "type": "string", "minLength": 1 },
                "pin": { "type": "string", "minLength": 1 },
                "mode": { "enum": ["input", "output", "high_z"] },
                "state": { "enum": ["high", "low", "z"] }
              },
              "additionalProperties": false
            }
          },
          "paths": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["driver", "victim"],
              "properties": {
                "driver": { "$ref": "#/$defs/endpoint" },
                "victim": { "$ref": "#/$defs/endpoint" },
                "series_resistance_ohm": { "type": "number", "minimum": 0 }
              },
              "additionalProperties": false
            }
          },
          "control_effects": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "source",
                "target",
                "asserted_state",
                "released_state",
                "release_delay_us"
              ],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "source": { "$ref": "#/$defs/endpoint" },
                "target": { "$ref": "#/$defs/endpoint" },
                "asserted_state": { "enum": ["high", "low", "z"] },
                "released_state": { "enum": ["high", "low", "z"] },
                "release_delay_us": { "type": "number", "minimum": 0 }
              },
              "additionalProperties": false
            }
          },
          "timing": {
            "type": "object",
            "properties": {
              "power_valid_at_us": { "type": "number", "minimum": 0 },
              "reset_release_at_us": { "type": "number", "minimum": 0 },
              "boot_sample_at_us": { "type": "number", "minimum": 0 },
              "reset_release_delay_us": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          },
          "straps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["component", "pin", "actual"],
              "properties": {
                "component": { "type": "string", "minLength": 1 },
                "pin": { "type": "string", "minLength": 1 },
                "net": { "type": "string", "minLength": 1 },
                "actual": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "required_boot_mode": { "type": "string", "minLength": 1 },
          "bootloader": {
            "type": "object",
            "properties": {
              "component": { "type": "string", "minLength": 1 },
              "interface": { "type": "string", "minLength": 1 },
              "sync_byte": { "type": "integer", "minimum": 0, "maximum": 255 },
              "expected_response": { "type": "integer", "minimum": 0, "maximum": 255 }
            },
            "additionalProperties": false
          },
          "protocol": {
            "type": "object",
            "required": ["name", "flow"],
            "properties": {
              "component": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 },
              "flow": { "type": "string", "minLength": 1 },
              "sender": { "$ref": "#/$defs/endpoint" },
              "package_size_bytes": { "type": "integer", "minimum": 0 },
              "package_sha256": {
                "type": "string",
                "pattern": "^[0-9a-fA-F]{64}$"
              },
              "chunk_size_bytes": { "type": "integer", "minimum": 0 },
              "expected_final_state": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "firmware": {
            "type": "object",
            "required": ["backend", "image", "expected_pin_states"],
            "properties": {
              "backend": { "enum": ["auto", "renode", "qemu"] },
              "image": { "type": "string", "minLength": 1 },
              "machine": { "type": "string", "minLength": 1 },
              "build": {
                "type": "object",
                "required": ["command"],
                "properties": {
                  "command": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "working_dir": { "type": "string", "minLength": 1 },
                  "outputs": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "timeout_ms": { "type": "integer", "minimum": 1 }
                },
                "additionalProperties": false
              },
              "qemu": {
                "type": "object",
                "properties": {
                  "executable": { "type": "string", "minLength": 1 },
                  "extra_args": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "timeout_ms": { "type": "integer", "minimum": 1 },
                  "pin_trace_prefix": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              },
              "expected_pin_states": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["component", "pin", "mode"],
                  "properties": {
                    "component": { "type": "string", "minLength": 1 },
                    "pin": { "type": "string", "minLength": 1 },
                    "mode": { "enum": ["input", "output", "high_z"] },
                    "state": { "enum": ["high", "low", "z"] }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "analog": {
            "type": "object",
            "required": [
              "backend",
              "model_files",
              "node_bindings",
              "pin_bindings",
              "analysis",
              "stimuli",
              "probes",
              "assertions"
            ],
            "properties": {
              "backend": { "enum": ["auto", "ngspice", "xyce", "embedded_ngspice"] },
              "netlist_source": { "enum": ["file", "generated_from_board"] },
              "netlist": { "type": "string", "minLength": 1 },
              "generated": {
                "type": "object",
                "required": ["components", "ground_net"],
                "properties": {
                  "components": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "ground_net": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              },
              "operating_conditions": {
                "type": "object",
                "properties": {
                  "ambient_temperature_c": { "type": "number" },
                  "allow_pulse_ratings": { "type": "boolean" }
                },
                "additionalProperties": false
              },
              "model_files": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["path"],
                  "properties": {
                    "path": { "type": "string", "minLength": 1 },
                    "sha256": {
                      "type": "string",
                      "pattern": "^[0-9a-fA-F]{64}$"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "node_bindings": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["node", "net"],
                  "properties": {
                    "node": { "type": "string", "minLength": 1 },
                    "net": { "type": "string", "minLength": 1 }
                  },
                  "additionalProperties": false
                }
              },
              "pin_bindings": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["node", "endpoint"],
                  "properties": {
                    "node": { "type": "string", "minLength": 1 },
                    "endpoint": { "$ref": "#/$defs/endpoint" }
                  },
                  "additionalProperties": false
                }
              },
              "analysis": {
                "type": "object",
                "required": ["type", "stop_time_us", "max_step_us"],
                "properties": {
                  "type": { "enum": ["tran"] },
                  "stop_time_us": { "type": "number", "exclusiveMinimum": 0 },
                  "max_step_us": { "type": "number", "exclusiveMinimum": 0 }
                },
                "additionalProperties": false
              },
              "stimuli": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "description"],
                  "properties": {
                    "name": { "type": "string", "minLength": 1 },
                    "description": { "type": "string", "minLength": 1 }
                  },
                  "additionalProperties": false
                }
              },
              "probes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["name", "expression"],
                  "properties": {
                    "name": { "type": "string", "minLength": 1 },
                    "expression": { "type": "string", "minLength": 1 },
                    "quantity": { "enum": ["voltage", "current", "power"] }
                  },
                  "additionalProperties": false
                }
              },
              "assertions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "probe",
                    "relation"
                  ],
                  "properties": {
                    "name": { "type": "string", "minLength": 1 },
                    "probe": { "type": "string", "minLength": 1 },
                    "at_us": { "type": "number", "minimum": 0 },
                    "start_us": { "type": "number", "minimum": 0 },
                    "end_us": { "type": "number", "minimum": 0 },
                    "aggregation": { "enum": ["sample", "min", "max"] },
                    "relation": { "enum": ["below", "above"] },
                    "threshold_v": { "type": "number" },
                    "threshold_a": { "type": "number" },
                    "threshold_w": { "type": "number" },
                    "suggested_fixes": {
                      "type": "array",
                      "items": { "type": "string", "minLength": 1 }
                    }
                  },
                  "allOf": [
                    {
                      "if": {
                        "required": ["aggregation"],
                        "properties": { "aggregation": { "enum": ["min", "max"] } }
                      },
                      "then": {
                        "required": ["start_us", "end_us"],
                        "not": { "required": ["at_us"] }
                      },
                      "else": {
                        "required": ["at_us"],
                        "not": {
                          "anyOf": [
                            { "required": ["start_us"] },
                            { "required": ["end_us"] }
                          ]
                        }
                      }
                    },
                    {
                      "oneOf": [
                        { "required": ["threshold_v"] },
                        { "required": ["threshold_a"] },
                        { "required": ["threshold_w"] }
                      ]
                    }
                  ],
                  "additionalProperties": false
                }
              }
            },
            "allOf": [
              {
                "if": {
                  "required": ["netlist_source"],
                  "properties": {
                    "netlist_source": { "const": "generated_from_board" }
                  }
                },
                "then": { "required": ["generated"] },
                "else": { "required": ["netlist"] }
              }
            ],
            "additionalProperties": false
          },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["at_us", "action"],
              "properties": {
                "at_us": { "type": "number", "minimum": 0 },
                "action": { "type": "string", "minLength": 1 },
                "from": { "$ref": "#/$defs/endpoint" },
                "to": { "$ref": "#/$defs/endpoint" },
                "bytes": {
                  "type": "array",
